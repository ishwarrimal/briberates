# Copy to .env.local and fill in.

# Supabase Postgres connection string (REQUIRED).
# Supabase dashboard → Project Settings → Database → Connection string → "URI".
# Use the "Session pooler" or "Transaction pooler" URI for deployment.
# Replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Public base URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://briberates.in

# Admin moderation password (defaults to "admin" if unset — CHANGE for production)
ADMIN_PASSWORD=

# Secret salt for hashing IPs / admin cookie (set a long random string in prod)
IP_HASH_SALT=

# Cloudflare Turnstile (anti-spam). If unset, the bot check is skipped (dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
